NODE_ENV=development
PORT=3000
APP_NAME=tash-api
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=tash
DATABASE_PASSWORD=tash
DATABASE_NAME=tash
DATABASE_SSL=false
# DATABASE_URL=postgres://tash:tash@localhost:5432/tash

REDIS_URL=redis://localhost:6379
SKIP_EXTERNAL_CONNECTIONS=false

JWT_ACCESS_TOKEN_SECRET=change-me-access-secret
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
VERIFICATION_TOKEN_TTL_SECONDS=86400
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800

BVN_ENCRYPTION_KEY=local-development-bvn-key-change-me
TRANSACTION_PIN_MAX_ATTEMPTS=5
TRANSACTION_PIN_LOCK_MINUTES=15
PAYMENT_PROVIDER=mock

TERMII_API_KEY="termii-api-key"
